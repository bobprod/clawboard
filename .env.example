# ──────────────────────────────────────────────────────────────────────────────
# ClawBoard — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env dans git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Serveur ───────────────────────────────────────────────────────────────────

# Port d'écoute du backend (défaut : 4000)
PORT=4000

# ── Sécurité — Authentification ───────────────────────────────────────────────

# Token secret partagé entre le frontend et le backend.
# Le frontend l'envoie via : Authorization: Bearer <token>
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLAWBOARD_SECRET=

# ── Frontend — Token d'authentification (Vite) ────────────────────────────────

# Doit être identique à CLAWBOARD_SECRET.
# Préfixe VITE_ requis pour être exposé côté navigateur par Vite.
VITE_AUTH_TOKEN=

# ── Sécurité — Chiffrement des clés API en mémoire (AES-256-GCM) ─────────────

# Clé de chiffrement (KEK) : exactement 64 caractères hexadécimaux (= 32 octets).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLAWBOARD_KEK=

# ── CORS — Origines autorisées ─────────────────────────────────────────────────

# Liste des origines autorisées, séparées par des virgules.
# En développement local : http://localhost:5173
# En production, remplacer par l'URL réelle du frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Clés API LLM (optionnel — peuvent aussi être configurées via l'UI) ─────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ── Base de données PostgreSQL ────────────────────────────────────────────────

# URL de connexion PostgreSQL (node-postgres / pg).
# Format : postgresql://<user>:<password>@<host>:<port>/<database>
# Créer la base dans pgAdmin : clic droit sur "Databases" → Create → Database → nom : clawboard
# Puis lancer la migration : node src/db/migrate.js
DATABASE_URL=postgresql://postgres:motdepasse@localhost:5432/clawboard
